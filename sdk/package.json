{
  "name": "@soroban-identity/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Soroban Identity protocol",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "~12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
